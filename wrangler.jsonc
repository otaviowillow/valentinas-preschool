{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "valentinas-preschool",
  "compatibility_date": "2026-06-19",
  // Build the static site before deploying so `wrangler deploy` always ships
  // fresh output (dist/ is gitignored, so it must be generated at deploy time).
  "build": {
    "command": "npm run build"
  },
  // Serve the Astro build output as static assets (no SSR adapter).
  "assets": {
    "directory": "./dist"
  }
}
