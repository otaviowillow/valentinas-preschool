---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/nunito-sans';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
import { getSettings, formatAgeRangeLabel } from '../lib/settings';
import { OG_IMAGE_PATH, SCHOOL_GEO, siteDescription } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  /** Extra JSON-LD objects (e.g. FAQPage, Course) for this page. */
  schema?: Record<string, unknown>[];
  noindex?: boolean;
}
const {
  title,
  description: descriptionProp,
  schema = [],
  noindex = false,
} = Astro.props;

const settings = await getSettings();
const description = descriptionProp ?? siteDescription(settings);

const pageTitle = title
  ? `${title} | ${site.name}`
  : `${site.name}: Reggio-Inspired Preschool in Culver City / West LA`;

const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(OG_IMAGE_PATH, site.url).href;
const ageRange = formatAgeRangeLabel(settings.ageMinMonths, settings.ageMaxMonths);

const { nap } = site;

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': ['ChildCare', 'Preschool', 'LocalBusiness'],
  name: site.name,
  description,
  url: site.url,
  telephone: nap.telephoneDisplay,
  image: ogImage,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: nap.streetAddress,
    addressLocality: nap.addressLocality,
    addressRegion: nap.addressRegion,
    postalCode: nap.postalCode,
    addressCountry: nap.addressCountry,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SCHOOL_GEO.latitude,
    longitude: SCHOOL_GEO.longitude,
  },
  areaServed: site.areasServed.map((name) => ({
    '@type': 'AdministrativeArea',
    name,
  })),
  founder: { '@type': 'Person', name: site.director },
  openingHours: 'Mo-Fr 07:30-18:00',
  sameAs: [site.social.instagram],
  knowsAbout: [
    'Reggio Emilia inspired early childhood education',
    'Bilingual Spanish immersion',
    'Toddler and preschool programs',
  ],
  additionalProperty: [
    {
      '@type': 'PropertyValue',
      name: 'Ages accepted',
      value: ageRange,
    },
    {
      '@type': 'PropertyValue',
      name: 'Meals included',
      value: 'Yes',
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#4a7c59" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(businessSchema)}
    />
    {
      schema.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      import { initContactForm } from '../scripts/contact-form.ts';
      import { initDatePickers } from '../scripts/date-picker.ts';
      import { bindSamePageNav } from '../scripts/site-nav.ts';

      bindSamePageNav();

      function initPageScripts() {
        initContactForm();
        initDatePickers();
      }

      initPageScripts();
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: 50%;
        transform: translateX(-50%) translateY(-150%);
        background: var(--color-primary-dark);
        color: var(--color-white);
        padding: 0.6rem 1.2rem;
        border-radius: 0 0 var(--radius) var(--radius);
        z-index: 100;
        transition: transform 0.2s;
      }
      .skip-link:focus {
        transform: translateX(-50%) translateY(0);
        color: var(--color-white);
      }
    </style>
  </body>
</html>
