---
export const prerender = false;

import { count, desc, eq, ne, sql } from 'drizzle-orm';
import AdminLayout from '../../layouts/AdminLayout.astro';
import StatusBadge from '../../components/admin/StatusBadge.astro';
import { dbFrom, schema } from '../../db';
import { money, formatDate } from '../../lib/format';

const db = dbFrom();
const { inquiries, children, classes, invoices, payments } = schema;

const [newInquiries] = await db
  .select({ c: count() })
  .from(inquiries)
  .where(eq(inquiries.status, 'new'));

const [enrolled] = await db
  .select({ c: count() })
  .from(children)
  .where(eq(children.status, 'enrolled'));

const [capacity] = await db
  .select({ total: sql<number>`coalesce(sum(${classes.capacity}), 0)` })
  .from(classes);

const [invoiced] = await db
  .select({ total: sql<number>`coalesce(sum(${invoices.amountCents}), 0)` })
  .from(invoices)
  .where(ne(invoices.status, 'void'));

const [paid] = await db
  .select({ total: sql<number>`coalesce(sum(${payments.amountCents}), 0)` })
  .from(payments);

const openSeats = Math.max(0, (capacity?.total ?? 0) - (enrolled?.c ?? 0));
const outstanding = (invoiced?.total ?? 0) - (paid?.total ?? 0);

const recent = await db
  .select()
  .from(inquiries)
  .orderBy(desc(inquiries.createdAt))
  .limit(6);
---

<AdminLayout title="Dashboard" active="dashboard">
  <div class="admin-head">
    <div>
      <h1>Dashboard</h1>
      <p>At-a-glance overview of enrollment, capacity, and billing.</p>
    </div>
  </div>

  <div class="admin-cards">
    <div class="admin-card">
      <div class="num">{newInquiries?.c ?? 0}</div>
      <div class="label">New inquiries</div>
      <a href="/admin/inquiries/">Review →</a>
    </div>
    <div class="admin-card">
      <div class="num">{enrolled?.c ?? 0}</div>
      <div class="label">Children enrolled</div>
      <a href="/admin/children/">Manage →</a>
    </div>
    <div class="admin-card">
      <div class="num">{openSeats}</div>
      <div class="label">Open seats</div>
      <a href="/admin/classes/">Classes →</a>
    </div>
    <div class="admin-card">
      <div class="num">{money(outstanding)}</div>
      <div class="label">Outstanding balance</div>
      <a href="/admin/billing/">Billing →</a>
    </div>
  </div>

  <section class="admin-panel">
    <div class="admin-toolbar">
      <h2>Recent inquiries</h2>
      <a class="admin-btn admin-btn--ghost admin-btn--sm" href="/admin/inquiries/"
        >View all</a
      >
    </div>
    {
      recent.length === 0 ? (
        <p class="admin-empty">
          No inquiries yet. They'll appear here when families submit the contact
          form.
        </p>
      ) : (
        <table class="admin-table">
          <thead>
            <tr>
              <th>Parent</th>
              <th>Child age</th>
              <th>Desired start</th>
              <th>Status</th>
              <th>Received</th>
              <th />
            </tr>
          </thead>
          <tbody>
            {recent.map((row) => (
              <tr>
                <td>{row.parentName}</td>
                <td>{row.childAge ?? '—'}</td>
                <td>{row.desiredStart ?? '—'}</td>
                <td>
                  <StatusBadge status={row.status} />
                </td>
                <td>{formatDate(row.createdAt)}</td>
                <td>
                  <a href={`/admin/inquiries/${row.id}/`}>Open</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )
    }
  </section>
</AdminLayout>
