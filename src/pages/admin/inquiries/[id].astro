---
export const prerender = false;

import { asc, eq } from 'drizzle-orm';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import StatusBadge from '../../../components/admin/StatusBadge.astro';
import { dbFrom, schema } from '../../../db';
import { formatDate, titleCase } from '../../../lib/format';
import { isReferralInquiry } from '../../../lib/inquiries';
import { INQUIRY_PIPELINE_STATUSES } from '../../../db/schema';

const id = Number(Astro.params.id);
const db = dbFrom();

const [inquiry] = Number.isInteger(id)
  ? await db.select().from(schema.inquiries).where(eq(schema.inquiries.id, id))
  : [];

if (!inquiry) return Astro.redirect('/admin/inquiries/');

const family = inquiry.familyId
  ? (
      await db
        .select()
        .from(schema.families)
        .where(eq(schema.families.id, inquiry.familyId))
    )[0]
  : null;

// Referral: the existing family that referred this lead (set by staff).
const allFamilies = await db
  .select()
  .from(schema.families)
  .orderBy(asc(schema.families.primaryContactName));
const referrer = inquiry.referredByFamilyId
  ? allFamilies.find((f) => f.id === inquiry.referredByFamilyId)
  : null;
const isReferral = isReferralInquiry(inquiry);
const isEnrolled = inquiry.status === 'enrolled';

const classList = await db
  .select()
  .from(schema.classes)
  .orderBy(asc(schema.classes.name));

const enrollNotes = inquiry.childAge
  ? `Age at inquiry: ${inquiry.childAge}`
  : '';

const familyDraft = {
  primaryContactName: family?.primaryContactName ?? inquiry.parentName,
  email: family?.email ?? inquiry.email ?? '',
  phone: family?.phone ?? inquiry.phone ?? '',
  address: family?.address ?? '',
  notes:
    family?.notes ??
    (inquiry.message ? `From inquiry #${id}: ${inquiry.message}` : ''),
};

const self = `/admin/inquiries/${id}/`;
---

<AdminLayout title="Inquiry" active="inquiries">
  <a class="admin-back" href={isReferral ? '/admin/referrals/' : '/admin/inquiries/'}>
    ← {isReferral ? 'All referrals' : 'All inquiries'}
  </a>

  <div class="admin-head">
    <div>
      <h1>{inquiry.parentName}</h1>
      <p>
        Received {formatDate(inquiry.createdAt)} · <StatusBadge
          status={inquiry.status}
        />
      </p>
    </div>
  </div>

  <div style="display:grid; grid-template-columns: 1fr 320px; gap: 1.5rem; align-items:start;" class="inquiry-grid">
    <section class="admin-panel">
      <h2>Details</h2>
      <table class="admin-table">
        <tbody>
          <tr><th>Email</th><td>{inquiry.email ?? '—'}</td></tr>
          <tr><th>Phone</th><td>{inquiry.phone ?? '—'}</td></tr>
          <tr><th>Child age</th><td>{inquiry.childAge ?? '—'}</td></tr>
          <tr><th>Desired start</th><td>{inquiry.desiredStart ?? '—'}</td></tr>
          <tr><th>Intent</th><td>{titleCase(inquiry.intent)}</td></tr>
          {
            isReferral && (
              <tr><th>Referred by</th><td>{inquiry.referredBy ?? '—'}</td></tr>
            )
          }
          <tr><th>Source</th><td>{inquiry.source ?? '—'}</td></tr>
          <tr>
            <th>Message</th>
            <td style="white-space: pre-wrap;">{inquiry.message ?? '—'}</td>
          </tr>
        </tbody>
      </table>
    </section>

    <aside class="inquiry-aside">
      <section class="admin-panel enroll-panel" id="enroll">
        <h2>Enroll</h2>
        {
          isEnrolled && family ? (
            <p style="margin:0;">
              Enrolled under{' '}
              <a href={`/admin/families/${family.id}/`}>
                {family.primaryContactName}
              </a>
              . Add siblings or update details from the family page.
            </p>
          ) : (
            <>
              <p class="muted" style="margin-top:0;">
                Confirm family contact info, then add the child. {
                  family
                    ? <>Updates the linked <a href={`/admin/families/${family.id}/`}>family record</a>.</>
                    : <>Creates a new family record.</>
                }
              </p>
              <form method="POST" action="/api/admin/inquiries/" class="admin-form">
                <input type="hidden" name="_action" value="enroll" />
                <input type="hidden" name="id" value={inquiry.id} />

                <h3 class="enroll-subhead">Family record</h3>
                <div class="admin-field">
                  <label for="primaryContactName">Primary contact name *</label>
                  <input
                    id="primaryContactName"
                    name="primaryContactName"
                    value={familyDraft.primaryContactName}
                    required
                  />
                </div>
                <div class="grid2">
                  <div class="admin-field">
                    <label for="email">Email</label>
                    <input
                      id="email"
                      name="email"
                      type="email"
                      value={familyDraft.email}
                    />
                  </div>
                  <div class="admin-field">
                    <label for="phone">Phone</label>
                    <input
                      id="phone"
                      name="phone"
                      type="tel"
                      value={familyDraft.phone}
                    />
                  </div>
                </div>
                <div class="admin-field">
                  <label for="address">Address</label>
                  <input id="address" name="address" value={familyDraft.address} />
                </div>
                <div class="admin-field">
                  <label for="familyNotes">Family notes</label>
                  <textarea id="familyNotes" name="familyNotes" rows="2">{familyDraft.notes}</textarea>
                </div>

                <h3 class="enroll-subhead">Child</h3>
                <div class="grid2">
                  <div class="admin-field">
                    <label for="firstName">First name *</label>
                    <input id="firstName" name="firstName" required />
                  </div>
                  <div class="admin-field">
                    <label for="lastName">Last name</label>
                    <input id="lastName" name="lastName" />
                  </div>
                </div>
                <div class="grid2">
                  <div class="admin-field">
                    <label for="dob">Date of birth</label>
                    <input id="dob" name="dob" type="date" />
                  </div>
                  <div class="admin-field">
                    <label for="classId">Class</label>
                    <select id="classId" name="classId">
                      <option value="">Unassigned</option>
                      {
                        classList.map((c) => (
                          <option value={c.id}>{c.name}</option>
                        ))
                      }
                    </select>
                  </div>
                </div>
                <div class="admin-field">
                  <label for="startDate">Start date</label>
                  <input
                    id="startDate"
                    name="startDate"
                    placeholder="e.g. Fall 2026"
                    value={inquiry.desiredStart ?? ''}
                  />
                </div>
                {
                  enrollNotes && (
                    <input type="hidden" name="childNotes" value={enrollNotes} />
                  )
                }
                <button type="submit" class="admin-btn">Enroll child</button>
              </form>
            </>
          )
        }
      </section>

      {
        !isEnrolled && (
          <section class="admin-panel">
            <h2>Status</h2>
            <form method="POST" action="/api/admin/inquiries/" class="admin-form">
              <input type="hidden" name="_action" value="status" />
              <input type="hidden" name="id" value={inquiry.id} />
              <input type="hidden" name="_redirect" value={self} />
              <div class="admin-field">
                <label for="status">Pipeline stage</label>
                <select id="status" name="status">
                  {
                    INQUIRY_PIPELINE_STATUSES.map((s) => (
                      <option value={s} selected={s === inquiry.status}>
                        {titleCase(s)}
                      </option>
                    ))
                  }
                </select>
              </div>
              <button type="submit" class="admin-btn admin-btn--ghost admin-btn--sm">
                Update status
              </button>
            </form>
          </section>
        )
      }

      {
        isReferral && (
          <section class="admin-panel" style="border-color:var(--color-accent);">
            <h2>Referral</h2>
            <p class="muted" style="margin-top:0;">
              Says they were referred by: <strong>{inquiry.referredBy ?? '—'}</strong>
            </p>

            <form method="POST" action="/api/admin/inquiries/" class="admin-form">
              <input type="hidden" name="_action" value="link_referrer" />
              <input type="hidden" name="id" value={inquiry.id} />
              <input type="hidden" name="_redirect" value={self} />
              <div class="admin-field">
                <label for="referredByFamilyId">Referring family</label>
                <select id="referredByFamilyId" name="referredByFamilyId">
                  <option value="">— Not linked —</option>
                  {
                    allFamilies.map((f) => (
                      <option
                        value={f.id}
                        selected={f.id === inquiry.referredByFamilyId}
                      >
                        {f.primaryContactName}
                      </option>
                    ))
                  }
                </select>
              </div>
              <button type="submit" class="admin-btn admin-btn--ghost admin-btn--sm">
                Link referrer
              </button>
            </form>

            {
              referrer && (
                <div style="margin-top:1rem;border-top:1px solid var(--color-surface-2);padding-top:1rem;">
                  <p style="margin:0 0 .5rem;">
                    Reward{' '}
                    <a href={`/admin/families/${referrer.id}/`}>
                      {referrer.primaryContactName}
                    </a>{' '}
                    with a referral credit:
                  </p>
                  <form
                    method="POST"
                    action="/api/admin/payments/"
                    class="admin-actions"
                  >
                    <input type="hidden" name="_action" value="create" />
                    <input type="hidden" name="familyId" value={referrer.id} />
                    <input type="hidden" name="method" value="referral credit" />
                    <input
                      type="hidden"
                      name="note"
                      value={`Referral credit — referred ${inquiry.parentName}`}
                    />
                    <input type="hidden" name="_redirect" value={self} />
                    <input
                      name="amount"
                      inputmode="decimal"
                      value="100"
                      style="width:6rem;padding:.4rem .5rem;border:1.5px solid var(--color-primary-light);border-radius:var(--radius);background:#fff;"
                      aria-label="Credit amount (USD)"
                    />
                    <button type="submit" class="admin-btn admin-btn--sm">
                      Apply credit
                    </button>
                  </form>
                  <p class="muted" style="font-size:.78rem;margin:.5rem 0 0;">
                    Recorded as a credit on their balance (Billing).
                  </p>
                </div>
              )
            }
          </section>
        )
      }

      <section class="admin-panel">
        <h2 style="color:#a51f1f;">Danger zone</h2>
        <form
          method="POST"
          action="/api/admin/inquiries/"
          onsubmit="return confirm('Delete this inquiry permanently?');"
        >
          <input type="hidden" name="_action" value="delete" />
          <input type="hidden" name="id" value={inquiry.id} />
          <input type="hidden" name="_redirect" value="/admin/inquiries/" />
          <button type="submit" class="admin-btn admin-btn--danger admin-btn--sm"
            >Delete inquiry</button
          >
        </form>
      </section>
    </aside>
  </div>
</AdminLayout>

<style>
  .enroll-panel {
    border-color: var(--color-primary);
  }

  .enroll-subhead {
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin: 1.25rem 0 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-surface-2);
  }

  .enroll-subhead:first-of-type {
    margin-top: 0.75rem;
    padding-top: 0;
    border-top: none;
  }

  @media (max-width: 860px) {
    .inquiry-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
