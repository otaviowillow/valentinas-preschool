---
export const prerender = false;

import { desc, eq, or, isNotNull } from 'drizzle-orm';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import StatusBadge from '../../../components/admin/StatusBadge.astro';
import { dbFrom, schema } from '../../../db';
import { formatDate, titleCase } from '../../../lib/format';
import { INQUIRY_STATUSES } from '../../../db/schema';

const db = dbFrom();
const filter = Astro.url.searchParams.get('status');
const validFilter = INQUIRY_STATUSES.find((s) => s === filter);

const intentFilter = Astro.url.searchParams.get('intent');
const validIntent = intentFilter === 'referral' ? 'referral' : null;

const rows = await db
  .select()
  .from(schema.inquiries)
  .where(
    validFilter
      ? eq(schema.inquiries.status, validFilter)
      : validIntent
        ? or(
            eq(schema.inquiries.intent, 'referral'),
            isNotNull(schema.inquiries.referredBy)
          )
        : undefined
  )
  .orderBy(desc(schema.inquiries.createdAt));
---

<AdminLayout title="Inquiries" active="inquiries">
  <div class="admin-head">
    <div>
      <h1>Inquiries</h1>
      <p>Enrollment leads from the website contact form.</p>
    </div>
  </div>

  <div class="admin-actions" style="margin-bottom: 1rem;">
    <a
      class={`admin-btn admin-btn--sm ${validFilter || validIntent ? 'admin-btn--ghost' : ''}`}
      href="/admin/inquiries/">All</a
    >
    <a
      class={`admin-btn admin-btn--sm ${validIntent ? '' : 'admin-btn--ghost'}`}
      href="/admin/inquiries/?intent=referral">Referrals</a
    >
    {
      INQUIRY_STATUSES.map((s) => (
        <a
          class={`admin-btn admin-btn--sm ${validFilter === s ? '' : 'admin-btn--ghost'}`}
          href={`/admin/inquiries/?status=${s}`}
        >
          {titleCase(s)}
        </a>
      ))
    }
  </div>

  <section class="admin-panel">
    {
      rows.length === 0 ? (
        <p class="admin-empty">
          No inquiries
          {validFilter ? ` with status “${validFilter}”` : validIntent ? ' tagged as referrals' : ''}{' '}
          yet.
        </p>
      ) : (
        <table class="admin-table">
          <thead>
            <tr>
              <th>Parent</th>
              <th>Contact</th>
              <th>Child age</th>
              <th>Desired start</th>
              <th>Intent</th>
              <th>Status</th>
              <th>Received</th>
              <th />
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr>
                <td>{row.parentName}</td>
                <td>
                  {row.email ?? row.phone ?? '—'}
                </td>
                <td>{row.childAge ?? '—'}</td>
                <td>{row.desiredStart ?? '—'}</td>
                <td>
                  {row.intent === 'referral' || row.referredBy ? (
                    <span class="badge badge--offered">Referral</span>
                  ) : (
                    titleCase(row.intent)
                  )}
                </td>
                <td>
                  <StatusBadge status={row.status} />
                </td>
                <td>{formatDate(row.createdAt)}</td>
                <td>
                  <a href={`/admin/inquiries/${row.id}/`}>Open</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )
    }
  </section>
</AdminLayout>
