---
export const prerender = false;

import { asc, desc } from 'drizzle-orm';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { dbFrom, schema } from '../../../db';
import { formatDate } from '../../../lib/format';

const db = dbFrom();
const classList = await db
  .select()
  .from(schema.classes)
  .orderBy(asc(schema.classes.name));
const classMap = new Map(classList.map((c) => [c.id, c.name]));

const announcements = await db
  .select()
  .from(schema.announcements)
  .orderBy(desc(schema.announcements.publishedAt));

const photos = await db
  .select()
  .from(schema.photos)
  .orderBy(desc(schema.photos.takenAt))
  .limit(60);
---

<AdminLayout title="Communications" active="comms">
  <div class="admin-head">
    <div>
      <h1>Communications</h1>
      <p>Post announcements and share daily photos.</p>
    </div>
  </div>

  <div class="grid-2col">
    <section class="admin-panel">
      <h2>New announcement</h2>
      <form method="POST" action="/api/admin/announcements/" class="admin-form">
        <input type="hidden" name="_action" value="create" />
        <input type="hidden" name="_redirect" value="/admin/comms/" />
        <div class="admin-field">
          <label for="title">Title *</label>
          <input id="title" name="title" required />
        </div>
        <div class="admin-field">
          <label for="body">Message *</label>
          <textarea id="body" name="body" rows="5" required></textarea>
        </div>
        <div class="grid2">
          <div class="admin-field">
            <label for="audience">Audience</label>
            <select id="audience" name="audience">
              <option value="all">All families</option>
              <option value="class">Specific class</option>
            </select>
          </div>
          <div class="admin-field">
            <label for="aclass">Class (if specific)</label>
            <select id="aclass" name="classId">
              <option value="">—</option>
              {classList.map((c) => <option value={c.id}>{c.name}</option>)}
            </select>
          </div>
        </div>
        <label class="email-opt">
          <input type="checkbox" name="email" /> Also email families
        </label>
        <div><button type="submit" class="admin-btn">Post announcement</button></div>
      </form>
    </section>

    <section class="admin-panel">
      <h2>Upload a photo</h2>
      <form
        id="photoForm"
        method="POST"
        action="/api/admin/photos/"
        class="admin-form"
        enctype="multipart/form-data"
      >
        <input type="hidden" name="_action" value="upload" />
        <input type="hidden" name="_redirect" value="/admin/comms/" />

        <div class="admin-field">
          <span class="dz-label">Image *</span>
          <div class="dropzone-wrap">
            <label class="dropzone" for="file" id="dropzone">
              <span class="dz-view dz-idle" data-state="idle">
                <span class="dz-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 18a4 4 0 0 1-.5-7.97 6 6 0 0 1 11.5-1.2A3.5 3.5 0 0 1 18 18z"/><path d="M12 12v6"/><path d="M9.5 14.5 12 12l2.5 2.5"/></svg>
                </span>
                <span class="dz-title">Tap to upload photo</span>
                <span class="dz-hint">PNG, JPG, WebP or GIF (max 10 MB)</span>
              </span>
              <span class="dz-view dz-busy" data-state="busy" hidden>
                <span class="dz-pct" id="dzPct">0%</span>
                <span class="dz-status">Uploading…</span>
              </span>
              <span class="dz-view dz-done" data-state="done" hidden>
                <span class="dz-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 7.5"/></svg>
                </span>
                <span class="dz-title">Upload complete</span>
              </span>
            </label>
            <input
              id="file"
              name="file"
              type="file"
              accept="image/png,image/jpeg,image/webp,image/gif"
              required
              hidden
            />
            <button type="button" class="dz-clear" id="dzClear" hidden>
              Clear
            </button>
          </div>
        </div>

        <div><button type="submit" class="admin-btn" id="photoSubmit">Upload photo</button></div>
      </form>
    </section>
  </div>

  <section class="admin-panel">
    <h2>Recent announcements</h2>
    {
      announcements.length === 0 ? (
        <p class="muted">No announcements yet.</p>
      ) : (
        <ul class="ann-list">
          {announcements.map((a) => (
            <li>
              <div>
                <strong>{a.title}</strong>
                <span class="muted">
                  {' '}
                  · {formatDate(a.publishedAt)} ·{' '}
                  {a.audience === 'class' && a.classId
                    ? (classMap.get(a.classId) ?? 'Class')
                    : 'All families'}
                </span>
                <p style="white-space:pre-wrap;margin:.35rem 0 0;">{a.body}</p>
              </div>
              <form method="POST" action="/api/admin/announcements/" onsubmit="return confirm('Delete this announcement?');">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={a.id} />
                <input type="hidden" name="_redirect" value="/admin/comms/" />
                <button class="admin-btn admin-btn--danger admin-btn--sm">Delete</button>
              </form>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="admin-panel">
    <h2>Photo gallery</h2>
    {
      photos.length === 0 ? (
        <p class="muted">No photos uploaded yet.</p>
      ) : (
        <div class="photo-grid">
          {photos.map((p) => (
            <figure class="photo">
              <img src={`/api/admin/media/${p.id}/`} alt={p.caption ?? 'Classroom photo'} loading="lazy" />
              <figcaption>
                <span>{p.caption ?? '—'}</span>
                <form method="POST" action="/api/admin/photos/" onsubmit="return confirm('Delete this photo?');">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={p.id} />
                  <input type="hidden" name="_redirect" value="/admin/comms/" />
                  <button class="admin-btn admin-btn--danger admin-btn--sm">×</button>
                </form>
              </figcaption>
            </figure>
          ))}
        </div>
      )
    }
  </section>
</AdminLayout>

<style>
  .grid-2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .ann-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .ann-list li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-surface-2);
  }
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
  }
  .photo {
    margin: 0;
    border: 1px solid var(--color-primary-light);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-surface);
  }
  .photo img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    display: block;
  }
  .photo figcaption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    font-size: 0.82rem;
  }
  @media (max-width: 860px) {
    .grid-2col {
      grid-template-columns: 1fr;
    }
  }

  /* ---- photo dropzone ---- */
  .dz-label {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-primary-dark);
    display: block;
    margin-bottom: 0.35rem;
  }
  .dropzone {
    display: block;
    border: 2px dashed var(--color-primary-light);
    border-radius: 12px;
    background: var(--admin-card);
    padding: 1rem 0.75rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .dropzone:hover,
  .dropzone.is-drag {
    border-color: var(--color-primary);
    background: var(--color-mint);
  }
  .dz-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .dz-view[hidden] {
    display: none !important;
  }
  .dz-icon {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: var(--color-mint);
    color: var(--color-primary);
  }
  .dz-icon svg { width: 1.15rem; height: 1.15rem; }
  .dz-title { font-weight: 800; font-size: 0.9rem; color: var(--color-primary-dark); }
  .dz-hint { font-size: 0.75rem; color: var(--color-ink-muted); }
  .dz-pct {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary-dark);
  }
  .dz-status { font-size: 0.78rem; color: var(--color-ink-muted); }
  .dz-check {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: var(--color-mint);
    color: var(--color-primary);
  }
  .dz-check svg { width: 1.25rem; height: 1.25rem; }
  .dz-clear {
    display: inline-flex;
    margin: 0.6rem auto 0;
    background: none;
    border: none;
    color: var(--color-secondary-dark);
    font: inherit;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>

<script data-astro-rerun>
  const form = document.getElementById('photoForm') as HTMLFormElement | null;
  const input = document.getElementById('file') as HTMLInputElement | null;
  const zone = document.getElementById('dropzone');
  const clearBtn = document.getElementById('dzClear');
  const submitBtn = document.getElementById('photoSubmit') as HTMLButtonElement | null;

  if (form && input && zone) {
    const idle = zone.querySelector('.dz-idle') as HTMLElement;
    const busy = zone.querySelector('.dz-busy') as HTMLElement;
    const done = zone.querySelector('.dz-done') as HTMLElement;
    const pct = document.getElementById('dzPct');

    const show = (state: 'idle' | 'busy' | 'done') => {
      idle.hidden = state !== 'idle';
      busy.hidden = state !== 'busy';
      done.hidden = state !== 'done';
    };

    const reset = () => {
      input.value = '';
      if (pct) pct.textContent = '0%';
      show('idle');
      if (clearBtn) clearBtn.hidden = true;
      if (submitBtn) submitBtn.disabled = false;
    };

    ['dragenter', 'dragover'].forEach((e) =>
      zone.addEventListener(e, (ev) => {
        ev.preventDefault();
        zone.classList.add('is-drag');
      })
    );
    ['dragleave', 'drop'].forEach((e) =>
      zone.addEventListener(e, (ev) => {
        ev.preventDefault();
        zone.classList.remove('is-drag');
      })
    );
    zone.addEventListener('drop', (ev) => {
      const dt = (ev as DragEvent).dataTransfer;
      if (dt?.files.length) {
        input.files = dt.files;
        input.dispatchEvent(new Event('change'));
      }
    });

    input.addEventListener('change', () => {
      if (input.files?.[0]) {
        if (clearBtn) clearBtn.hidden = false;
      }
    });

    if (clearBtn) clearBtn.addEventListener('click', reset);

    form.addEventListener('submit', (ev) => {
      const f = input.files?.[0];
      if (!f) return;
      ev.preventDefault();
      if (submitBtn) submitBtn.disabled = true;
      if (pct) pct.textContent = '0%';
      show('busy');
      if (clearBtn) clearBtn.hidden = true;

      const xhr = new XMLHttpRequest();
      xhr.open('POST', form.action);
      xhr.upload.addEventListener('progress', (e) => {
        if (!e.lengthComputable || !pct) return;
        pct.textContent = Math.round((e.loaded / e.total) * 100) + '%';
      });
      xhr.addEventListener('load', () => {
        if (xhr.status >= 200 && xhr.status < 400) {
          if (pct) pct.textContent = '100%';
          show('done');
          setTimeout(() => {
            window.location.href = '/admin/comms/?flash=Photo uploaded.';
          }, 600);
        } else {
          reset();
          alert('Upload failed. Please try again.');
        }
      });
      xhr.addEventListener('error', () => {
        reset();
        alert('Upload failed. Please try again.');
      });
      xhr.send(new FormData(form));
    });

    show('idle');
  }
</script>
