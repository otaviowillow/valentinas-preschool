---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { formatAgeRangeLabel, getSettings } from '../../../lib/settings';

const s = await getSettings();
const agePreview = formatAgeRangeLabel(s.ageMinMonths, s.ageMaxMonths);
---

<AdminLayout title="Site settings" active="settings">
  <div class="admin-head">
    <div>
      <h1>Site settings</h1>
      <p>Public-site age range, tuition, discounts, and referral offer.</p>
    </div>
  </div>

  <section class="admin-panel">
    <form method="POST" action="/api/admin/settings/" class="admin-form">
      <input type="hidden" name="_action" value="update" />
      <input type="hidden" name="_redirect" value="/admin/settings/" />

      <h2 style="margin:0 0 0.5rem;font-size:1.05rem;">Enrollment ages</h2>
      <p class="muted" style="margin:0 0 1rem;font-size:0.85rem;">
        Shown on the home page, programs, tuition FAQ, and contact form. Preview: <strong>{agePreview}</strong>
      </p>
      <div class="grid2">
        <div class="admin-field">
          <label for="ageMinMonths">Minimum age (months)</label>
          <input id="ageMinMonths" name="ageMinMonths" type="number" min="1" max="84" value={s.ageMinMonths} required />
        </div>
        <div class="admin-field">
          <label for="ageMaxMonths">Maximum age (months)</label>
          <input id="ageMaxMonths" name="ageMaxMonths" type="number" min="1" max="84" value={s.ageMaxMonths} required />
        </div>
      </div>

      <div class="grid2">
        <div class="admin-field">
          <label for="capacity">Total capacity (spots)</label>
          <input id="capacity" name="capacity" type="number" min="0" max="500" value={s.capacity} />
        </div>
        <div class="admin-field">
          <label for="applicationFee">Application fee ($)</label>
          <input id="applicationFee" name="applicationFee" type="number" min="0" value={s.applicationFee} />
        </div>
      </div>

      <h2 style="margin:1.25rem 0 0.5rem;font-size:1.05rem;">Part-time plan</h2>
      <div class="grid2">
        <div class="admin-field">
          <label for="partTimeLabel">Label</label>
          <input id="partTimeLabel" name="partTimeLabel" value={s.partTimeLabel} required />
        </div>
        <div class="admin-field">
          <label for="partTimePrice">Price text</label>
          <input id="partTimePrice" name="partTimePrice" value={s.partTimePrice} required />
        </div>
      </div>
      <div class="admin-field">
        <label for="partTimeNote">Note</label>
        <input id="partTimeNote" name="partTimeNote" value={s.partTimeNote} />
      </div>

      <h2 style="margin:1.25rem 0 0.5rem;font-size:1.05rem;">Full-time plan</h2>
      <div class="grid2">
        <div class="admin-field">
          <label for="fullTimeLabel">Label</label>
          <input id="fullTimeLabel" name="fullTimeLabel" value={s.fullTimeLabel} required />
        </div>
        <div class="admin-field">
          <label for="weeklyFrom">Weekly rate from ($/wk)</label>
          <input id="weeklyFrom" name="weeklyFrom" type="number" min="0" value={s.weeklyFrom} />
        </div>
      </div>
      <div class="admin-field">
        <label for="fullTimeNote">Note</label>
        <input id="fullTimeNote" name="fullTimeNote" value={s.fullTimeNote} />
      </div>
      <p class="muted" style="margin:0;font-size:0.85rem;">
        Full-time price displays as “from ${s.weeklyFrom}/wk”.
      </p>

      <div class="admin-field" style="margin-top:1rem;">
        <label for="tuitionNote">Tuition note (FAQ / pricing footnote)</label>
        <textarea id="tuitionNote" name="tuitionNote" rows="2">{s.tuitionNote}</textarea>
      </div>

      <div class="admin-field">
        <label class="email-opt" style="flex-direction:row;display:flex;gap:0.5rem;align-items:center;font-weight:600;">
          <input type="checkbox" name="siblingDiscount" checked={s.siblingDiscount} /> Sibling discount available
        </label>
      </div>
      <div class="admin-field">
        <label for="siblingDiscountNote">Sibling discount description</label>
        <textarea id="siblingDiscountNote" name="siblingDiscountNote" rows="2">{s.siblingDiscountNote}</textarea>
      </div>

      <div class="admin-field">
        <label class="email-opt" style="flex-direction:row;display:flex;gap:0.5rem;align-items:center;font-weight:600;">
          <input type="checkbox" name="subsidiesAccepted" checked={s.subsidiesAccepted} /> Childcare subsidies accepted
        </label>
      </div>

      <h2 style="margin:1.25rem 0 0.5rem;font-size:1.05rem;">Referral offer (tuition page)</h2>
      <div class="admin-field">
        <label class="email-opt" style="flex-direction:row;display:flex;gap:0.5rem;align-items:center;font-weight:600;">
          <input type="checkbox" name="referralEnabled" checked={s.referralEnabled} /> Show referral offer on tuition page
        </label>
      </div>
      <div class="admin-field">
        <label for="referralTitle">Referral headline</label>
        <input id="referralTitle" name="referralTitle" value={s.referralTitle} required />
      </div>
      <div class="admin-field">
        <label for="referralBody">Referral description</label>
        <textarea id="referralBody" name="referralBody" rows="3" required>{s.referralBody}</textarea>
      </div>

      <div><button type="submit" class="admin-btn">Save settings</button></div>
    </form>
  </section>
</AdminLayout>
