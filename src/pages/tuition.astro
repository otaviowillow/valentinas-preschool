---
// SSR so office edits in /admin/settings show here without a rebuild.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../data/site';
import { getSettings } from '../lib/settings';
import { buildHolidayFaqAnswer, getHolidaySchedule } from '../lib/holidays';
import { faqPageSchema, tuitionFaqs } from '../lib/seo';

const settings = await getSettings();
const holidaySchedule = await getHolidaySchedule();

const plans = [
  {
    name: settings.partTimeLabel,
    price: settings.partTimePrice,
    note: settings.partTimeNote,
  },
  {
    name: settings.fullTimeLabel,
    price: 'Contact us',
    note: settings.fullTimeNote,
    featured: true,
  },
];

const faqs = [
  ...tuitionFaqs(settings),
  {
    q: 'What is teacher-to-child ratios?',
    a: `Our typical teacher-to-child ratio is ${site.facts.ratio}.`,
  },
  {
    q: 'When is the school closed for holidays?',
    a: buildHolidayFaqAnswer(holidaySchedule),
    preline: true,
  },
];
const faqSchema = faqPageSchema(faqs);
---

<BaseLayout
  title="Tuition & FAQ · Culver City Preschool"
  description="Tuition, fees, hours, meals, sibling discounts, and subsidies at Valentina's Preschool in Culver City / West LA. Enrichment always included."
  schema={[faqSchema]}
>
  <PageHero
    eyebrow="Tuition & FAQ"
    title="Tuition & FAQ for Culver City families"
    lead="One tuition covers everything: enrichment, daily Spanish, and meals included. No surprise add-ons."
  />

  <section class="section section--cream">
    <div class="container">
      <div class="grid grid-3 plans">
        {
          plans.map((p) => (
            <article class:list={['card plan stack', { 'plan--featured': p.featured }]}>
              {p.featured && <span class="plan__tag">Most popular</span>}
              <h3>{p.name}</h3>
              <p class="plan__price">{p.price}</p>
              <p class="muted">{p.note}</p>
            </article>
          ))
        }
      </div>
      <p class="fees muted">
        One-time application fee: <strong>${settings.applicationFee}</strong>
        {settings.siblingDiscount && <> · Sibling discount available</>}
        {settings.subsidiesAccepted && <> · Childcare subsidies accepted</>}
      </p>
      <p class="cap-note">
        A boutique program with limited enrollment — contact us for current availability.
      </p>
      <p class="confirm-note">{settings.tuitionNote}</p>

      {
        settings.referralEnabled && (
          <div class="referral">
            <span class="referral__badge">Referral offer</span>
            <h3>{settings.referralTitle}</h3>
            <p>{settings.referralBody}</p>
            <a href="/contact/" class="btn btn--primary">Refer a family</a>
          </div>
        )
      }
    </div>
  </section>

  <section class="section section--sand" id="faq">
    <div class="container-narrow">
      <div class="section-head">
        <h2>Frequently asked questions</h2>
      </div>
      <div class="faqs">
        {
          faqs.map((f) => (
            <details class="faq">
              <summary>{f.q}</summary>
              <p class:list={[{ 'faq__preline': 'preline' in f && f.preline }]}>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  .plans {
    align-items: stretch;
  }
  .plan {
    text-align: center;
    align-items: center;
  }
  .plan--featured {
    border-color: var(--color-secondary);
    border-width: 2px;
    position: relative;
  }
  .plan__tag {
    position: absolute;
    top: -0.8rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-secondary);
    color: var(--color-white);
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.25rem 0.85rem;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .plan__price {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--color-secondary-dark);
  }
  .fees {
    text-align: center;
    margin-top: 1.75rem;
  }
  .confirm-note {
    text-align: center;
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }
  .cap-note {
    text-align: center;
    color: var(--color-primary-dark);
    font-weight: 700;
    margin-top: 0.4rem;
  }
  .referral {
    margin-top: 2.5rem;
    text-align: center;
    background: var(--color-peach);
    border: 1px solid var(--color-secondary);
    border-radius: var(--radius-lg);
    padding: clamp(1.75rem, 4vw, 2.5rem);
  }
  .referral__badge {
    display: inline-block;
    background: var(--color-secondary);
    color: var(--color-white);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.85rem;
    border-radius: var(--radius-pill);
  }
  .referral h3 {
    margin-top: 0.9rem;
  }
  .referral p {
    max-width: 32rem;
    margin: 0.6rem auto 1.4rem;
  }
  #faq {
    scroll-margin-top: 5rem;
  }
  .faqs {
    display: grid;
    gap: 0.75rem;
    overflow-anchor: none;
  }
  .faq {
    background: var(--color-white);
    border: 1px solid rgba(167, 196, 176, 0.5);
    border-radius: var(--radius);
    padding: 0 1.25rem;
    overflow-anchor: none;
  }
  .faq summary {
    cursor: pointer;
    font-weight: 800;
    color: var(--color-primary-dark);
    padding: 1.1rem 0;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    scroll-margin-top: 5rem;
  }
  .faq summary::after {
    content: '+';
    font-size: 1.5rem;
    color: var(--color-secondary);
    transition: transform 0.2s;
  }
  .faq[open] summary::after {
    transform: rotate(45deg);
  }
  .faq summary::-webkit-details-marker {
    display: none;
  }
  .faq p {
    padding-bottom: 1.1rem;
    margin: 0;
  }
  .faq__preline {
    white-space: pre-line;
  }
</style>
