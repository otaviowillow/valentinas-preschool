---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <section class="section section--cream">
    <div class="container-narrow text-center stack">
      <p class="eyebrow">404</p>
      <h1>This little one wandered off</h1>
      <p class="lead muted">
        We couldn’t find that page. Let’s get you back to somewhere friendly.
      </p>
      <p>
        <a href="/" class="btn btn--primary">Back home</a>
        <a href="/contact/" class="btn btn--ghost">Book a tour</a>
      </p>
    </div>
  </section>
</BaseLayout>
