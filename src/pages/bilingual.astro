---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Img from '../components/Img.astro';
import CtaBand from '../components/CtaBand.astro';
---

<BaseLayout
  title="Bilingual Preschool: Daily Spanish Immersion in West LA"
  description="Valentina's is a bilingual preschool in Culver City / West LA with daily Spanish. Children learn through songs, play, and conversation, building familiarity with a second language."
>
  <PageHero
    eyebrow="Bilingual · Daily Spanish"
    title="Two languages, woven through every day"
    lead="Spanish isn’t a once-a-week class here. It lives in our songs, our play, and our everyday conversation. Many of our little ones leave us teaching their parents new words."
  />

  <section class="section section--cream">
    <div class="container grid grid-2" style="align-items:center">
      <Img name="bilingual" ratio="4/3" />
      <div class="stack">
        <h2>Why a second language, so early?</h2>
        <p>
          The early years are the easiest time to absorb a second language.
          Research links early bilingualism to stronger verbal communication,
          mathematical reasoning, and problem-solving, plus a deeper cultural
          awareness and appreciation of differences.
        </p>
        <p>
          Our families tell us their children come home singing in Spanish and
          growing more comfortable with the language every week, a gift that lasts a lifetime.
        </p>
        <blockquote class="pull">
          “She practices Spanish daily and now knows more than we do!”
          <cite>Diana D., parent</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  .pull {
    border-left: 4px solid var(--color-accent);
    padding: 0.5rem 0 0.5rem 1.25rem;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: var(--color-primary-dark);
  }
  .pull cite {
    display: block;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-style: normal;
    color: var(--color-ink-muted);
    margin-top: 0.5rem;
  }
</style>
