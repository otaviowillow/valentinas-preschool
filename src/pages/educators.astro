---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Img from '../components/Img.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../data/site';

const team = [
  {
    name: 'Valentina Gloginic',
    role: 'Founder & Director',
    bio: 'The heart of the school, with over a decade of dedication to our community. Valentina holds a Bachelor’s Degree and an On-Site Supervisor / Master Teacher certificate from California Teacher Credentialing, and is also a music, dance, and yoga teacher for young children. Her passion is positive discipline that helps children build genuine emotional intelligence, and she keeps sharpening her craft with cutting-edge child-development courses.',
    img: 'eduValentina',
    bookAuthor: true,
  },
  {
    name: 'Andrea',
    role: 'Part-time Teacher',
    bio: 'Andrea holds a degree in Child Clinical Psychology from Cornell University and has extensive experience supporting children and families through programs across Los Angeles, including Venice Arts, Dream Street Camp, and No Limits for Deaf and Hard of Hearing children. In addition to her work in early childhood education, she writes for preschool television and picture books. As a Palms/Culver City native, she is delighted to serve as a part-time preschool teacher for Valentina’s Preschool and support families in the community she calls home.',
    img: null,
  },
  {
    name: 'Ashley A.',
    role: 'Teacher',
    bio: 'Holds an Associate Teacher certificate and permit from California Teacher Credentialing. Ashley is deeply passionate about young children and brings creativity and a unique spark to an engaging learning environment.',
    img: null,
  },
  {
    name: 'Amanda',
    role: 'Teacher',
    bio: 'Amanda recently earned her bachelor’s degree in Psychology and is currently pursuing her Master’s in Applied Behavior Analysis (ABA). She has supported young children in both preschool and behavioral therapy settings, and loves building meaningful connections that help each child feel confident, valued, and excited to explore. At Valentina’s Preschool, she strives to create a warm, nurturing, and engaging environment where every child feels safe, supported, and loved as they learn and grow.',
    img: null,
  },
  {
    name: 'Milagros B. (“Mila”)',
    role: 'Teacher’s Assistant',
    bio: 'A dedicated part of our family for nearly a decade. With a background as a social worker in Peru and 15+ years assisting in Los Angeles classrooms, Mila is the backbone of our daily routines, and our students’ well-being.',
    img: null,
  },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.director,
  jobTitle: 'Founder & Director',
  worksFor: { '@type': 'Preschool', name: site.name },
  description:
    'Founder and Director of Valentina’s Preschool. Master Teacher certified, with a decade-plus dedicated to early childhood education in West Los Angeles.',
};
---

<BaseLayout
  title="Meet Valentina & Our Educators"
  description="Meet Valentina Gloginic, founder, director, and Master Teacher, and the experienced, loving team behind Valentina's Preschool in Culver City / West LA."
  schema={[personSchema]}
>
  <PageHero
    eyebrow="Our Educators"
    title="The people your child will love"
    lead="A small, experienced team that believes children don’t just learn here. They flourish, emotionally, socially, and creatively."
  />

  <section class="section section--cream">
    <div class="container stack-lg">
      {
        team.map((m) => (
          <article class:list={['member', { 'member--text': !m.img }]}>
            {m.img && <Img name={m.img as any} ratio="1/1" />}
            <div class="stack">
              <p class="eyebrow">{m.role}</p>
              <h2>{m.name}</h2>
              <p>
                {m.bio}
                {
                  m.bookAuthor && (
                    <>
                      {' '}She is also the author of{' '}
                      <a class="member__book-link" href={site.book.href} rel="noopener noreferrer" target="_blank">
                        {site.book.title}
                      </a>
                      .
                    </>
                  )
                }
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <CtaBand
    title="Meet our educators in person"
    text="Bios only say so much. Come by for a tour and feel the warmth for yourself."
  />
</BaseLayout>

<style>
  .stack-lg > * + * {
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }
  .member {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 42rem;
    margin-inline: auto;
  }
  .member .stack {
    align-items: center;
  }
  .member--text {
    max-width: 40rem;
  }
  .member h2 {
    margin-top: 0.2rem;
  }
  .member__book-link {
    font-weight: 700;
    color: var(--color-secondary-dark);
    text-decoration: none;
  }
  .member__book-link:hover {
    text-decoration: underline;
  }
  .member :global(.img) {
    max-width: 18rem;
    margin-inline: auto;
  }
  .member:first-child :global(.img) {
    object-position: center 78%;
  }

  @media (min-width: 881px) {
    .member {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: clamp(1.5rem, 3vw, 2.5rem);
      max-width: none;
      margin-inline: 0;
    }
    .member .stack {
      align-items: flex-start;
      flex: 1;
    }
    .member--text {
      max-width: 48rem;
    }
    .member :global(.img) {
      flex-shrink: 0;
      width: min(18rem, 30%);
      margin-inline: 0;
    }
  }
</style>
