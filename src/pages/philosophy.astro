---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Img from '../components/Img.astro';
import CtaBand from '../components/CtaBand.astro';

const beliefs = [
  {
    title: 'Learning is a process',
    body: 'Figuring things out, making connections, testing ideas, taking risks, and trying again, without fear of ridicule. We give children the time and space to investigate their own ideas.',
  },
  {
    title: 'The teacher is a collaborator',
    body: 'Not someone who controls learning, but a patient observer who respects and trusts each child, models curiosity, celebrates good ideas, and helps troubleshoot when things go wrong.',
  },
  {
    title: 'A hundred languages',
    body: 'Children express themselves through painting, drawing, sculpting, dance, movement, and pretend play. Each of these languages is valued and nurtured.',
  },
  {
    title: 'Documentation',
    body: 'Every child receives a binder upon enrollment where we save projects and notes. Documenting helps us, and you, truly understand your child’s learning.',
  },
  {
    title: 'Family is essential',
    body: 'We work closely with parents, host potlucks to build community, and invite parents with special skills to share them in the classroom.',
  },
  {
    title: 'Room to be an individual',
    body: 'Because the world is complex, we offer both group activities and the privacy to play or work alone, honoring each child’s pace.',
  },
];
---

<BaseLayout
  title="Our Philosophy: Reggio Emilia–Inspired Preschool"
  description="Valentina's Preschool is a Reggio Emilia–inspired preschool in Culver City / West LA. Child-led exploration, the hundred languages, and documentation for every child."
>
  <PageHero
    compact
    eyebrow="Our Philosophy"
    title="A Reggio Emilia–inspired approach to the early years"
    lead="We believe children learn through active exploration and play, and that a child’s self-esteem is built on mutual respect between adults and children alike."
  />

  <section class="section section--cream" style="padding-top: 0">
    <div class="container grid grid-2" style="align-items:center">
      <Img name="philosophyObserve" ratio="4/3" />
      <div class="stack">
        <p>
          An optimum learning environment provides opportunities to explore, and
          to investigate questions and ideas. A real teacher supports that
          process rather than trying to create, control, or manipulate it.
        </p>
        <p>
          That means respecting and trusting our learners, talking <em>with</em>
          them, sharing and modeling learning, supporting the risk- and
          mistake-making process, and celebrating good ideas and satisfying
          accomplishments.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--sand">
    <div class="container">
      <div class="section-head center">
        <h2>What we believe</h2>
      </div>
      <div class="grid grid-3">
        {
          beliefs.map((b) => (
            <article class="card stack">
              <h3>{b.title}</h3>
              <p>{b.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="See our philosophy in action"
    text="The best way to understand how we teach is to visit. Book a tour and watch a typical morning unfold."
  />
</BaseLayout>
