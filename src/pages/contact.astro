---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import DatePicker from '../components/DatePicker.astro';
import { site } from '../data/site';
import { formatAgeRangeLabel, getSettings } from '../lib/settings';

const settings = await getSettings();
const ageRange = formatAgeRangeLabel(settings.ageMinMonths, settings.ageMaxMonths);

const { nap } = site;
const minStartDate = new Date().toISOString().slice(0, 10);
const maxStartDate = new Date(
  new Date().getFullYear() + 3,
  new Date().getMonth(),
  new Date().getDate()
)
  .toISOString()
  .slice(0, 10);
const mapQuery = encodeURIComponent(
  `${nap.streetAddress}, ${nap.addressLocality}, ${nap.addressRegion} ${nap.postalCode}`
);
---

<BaseLayout
  title="Book a Tour & Contact"
  description={`Book a tour at Valentina's Preschool — toddler & preschool childcare in Culver City / Palms (${site.nap.postalCode}). Ages ${ageRange}. Call ${nap.telephoneDisplay}.`}
>
  <PageHero
    eyebrow="Visit Us · Culver City / West LA"
    title="Book a tour at our Culver City preschool"
    lead="Spots are limited. Tell us about your child and we’ll reply personally — usually within one business day."
  />

  <section class="section section--cream">
    <div class="container contact-grid">
      <form
        class="card contact-form"
        action="/api/inquiries/"
        method="POST"
        novalidate
        data-age-min={settings.ageMinMonths}
        data-age-max={settings.ageMaxMonths}
      >
        <h2>Request a tour</h2>

        <p class="form-error" id="form-error" role="alert" hidden>
          Sorry — something went wrong. Please check your details and try again,
          or call us directly.
        </p>

        {/* Honeypots: hidden from people, tempting to bots. Leave empty. */}
        <div class="hp" aria-hidden="true">
          <label for="website">Website</label>
          <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
          <label for="company">Company</label>
          <input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="form_ts" id="form_ts" value="" />

        <div class="field">
          <label for="parent">Your name</label>
          <input
            id="parent"
            name="parent_name"
            type="text"
            required
            maxlength="100"
            autocomplete="name"
          />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            maxlength="200"
            autocomplete="email"
            inputmode="email"
            aria-describedby="email-error"
          />
          <p class="field-error" id="email-error" role="alert" hidden></p>
        </div>

        <div class="field">
          <label for="phone">Phone</label>
          <input
            id="phone"
            name="phone"
            type="tel"
            maxlength="10"
            autocomplete="tel"
            inputmode="numeric"
            pattern="[0-9]{10}"
            placeholder="3105551234"
            aria-describedby="phone-error"
          />
          <p class="field-error" id="phone-error" role="alert" hidden></p>
        </div>

        <div class="field">
          <label for="childage">Child’s age (months)</label>
          <input
            id="childage"
            name="child_age"
            type="number"
            min={settings.ageMinMonths}
            max={settings.ageMaxMonths}
            step="1"
            placeholder="e.g. 24"
            required
          />
          <span class="muted field-hint">Ages {ageRange} ({settings.ageMaxMonths} months max).</span>
        </div>

        <div class="field">
          <label id="start-label" for="start-trigger">Desired start</label>
          <DatePicker id="start" name="start_date" min={minStartDate} max={maxStartDate} />
        </div>

        <fieldset class="field intent-field">
          <legend>I’d like to…</legend>
          <div class="intent-options">
            <label class="radio"
              ><input type="radio" name="intent" value="tour" checked /> Book a tour</label
            >
            <label class="radio"
              ><input type="radio" name="intent" value="waitlist" /> Join the waitlist</label
            >
          </div>
        </fieldset>

        <div class="field referred-check">
          <label class="checkbox">
            <input type="checkbox" id="was-referred" value="1" />
            I was referred by a family
          </label>
        </div>

        <div class="field referred-by" hidden>
          <label for="referred">Who referred you?</label>
          <input
            id="referred"
            name="referred_by"
            type="text"
            placeholder="Name of individual who referred you"
            maxlength="200"
          />
        </div>

        <div class="field">
          <label for="message">Anything we should know?</label>
          <textarea id="message" name="message" rows="4" maxlength="2000"></textarea>
        </div>

        <button type="submit" class="btn btn--primary btn--lg" disabled>
          Send request
        </button>
        <p class="muted form-fallback">
          Prefer to talk? Call <a href={`tel:${nap.telephoneHref}`}>{nap.telephoneDisplay}</a>.
        </p>
      </form>

      <aside class="contact-info stack">
        <div class="card stack">
          <h2>Find us</h2>
          <address>
            {nap.streetAddress}<br />
            {nap.addressLocality}, {nap.addressRegion} {nap.postalCode}
          </address>
          <p>
            <a href={`tel:${nap.telephoneHref}`}>{nap.telephoneDisplay}</a>
          </p>
          <p><strong>Hours:</strong><br />{site.facts.hours}</p>
          <p>
            <a href={site.social.instagram} rel="noopener" target="_blank"
              >{site.social.instagramHandle}</a
            >
          </p>
          <p class="muted">
            Licensed #{site.facts.license} · {site.facts.accreditation}
          </p>
        </div>
        <iframe
          class="map"
          title="Map to Valentina's Preschool"
          src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border: 0;
    padding: 0;
    margin: 0;
  }
  .intent-field {
    gap: 0.75rem;
  }
  .intent-options {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  label,
  legend {
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--color-primary-dark);
  }
  input,
  textarea {
    font: inherit;
    padding: 0.7rem 0.9rem;
    border: 1.5px solid var(--color-primary-light);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-ink);
  }
  input:focus,
  textarea:focus {
    border-color: var(--color-primary);
    outline: none;
  }
  input.is-invalid,
  textarea.is-invalid {
    border-color: #a51f1f;
    background: #fff6f5;
    box-shadow: inset 0 0 0 1px rgba(165, 31, 31, 0.15);
  }
  input.is-invalid:focus,
  textarea.is-invalid:focus {
    border-color: #a51f1f;
    outline: 2px solid rgba(165, 31, 31, 0.3);
    outline-offset: 1px;
  }
  .field-error {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: #a51f1f;
  }
  .field-error:not([hidden]) {
    display: block;
  }
  .radio {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }
  .checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    cursor: pointer;
  }
  .referred-check {
    margin-top: -0.35rem;
  }
  .field-hint {
    font-size: 0.85rem;
  }
  .form-fallback {
    margin: 0.9rem 0 0;
    font-size: 0.9rem;
  }
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .form-error {
    margin: 0;
    padding: 0.7rem 1rem;
    border-radius: var(--radius);
    background: #fbdcd6;
    color: #a51f1f;
    border: 1px solid #a51f1f;
    font-weight: 600;
  }
  .contact-info address {
    font-style: normal;
    line-height: 1.6;
  }
  .map {
    width: 100%;
    height: 320px;
    border: 0;
    border-radius: var(--radius-lg);
  }
  @media (max-width: 880px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
