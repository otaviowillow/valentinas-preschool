---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';
import Img from '../components/Img.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../data/site';
import { testimonials } from '../data/testimonials';
import { images } from '../data/images';
import { formatAgeRangeLabel, getSettings } from '../lib/settings';
import { siteDescription, bookSchema } from '../lib/seo';

import iconAcademic from '../assets/photos/academic.png';
import iconArts from '../assets/photos/arts.png';
import iconPhysical from '../assets/photos/physical.png';
import iconLife from '../assets/photos/life.png';
import iconSocial from '../assets/photos/social.png';
import bookCover from '../assets/book-cover.png';

const settings = await getSettings();
const ageRange = formatAgeRangeLabel(settings.ageMinMonths, settings.ageMaxMonths);
const metaDescription = siteDescription(settings);
const optimizedBookCover = await getImage({ src: bookCover, width: 480, format: 'webp' });
const bookCoverUrl = new URL(optimizedBookCover.src, site.url).href;
const homepageSchema = [bookSchema(bookCoverUrl)];

const featured = testimonials.slice(0, 3);

// Full-bleed hero photo (LCP element): self-hosted, optimized to responsive
// WebP and served eagerly with high fetch priority so mobile downloads a
// right-sized image and it paints fast. Swap the source in src/data/images.ts.
const heroAsset = images.hero.asset!;

const stats = [
  { num: site.yearsServing, label: 'years in the neighborhood' },
  { num: '2', label: 'languages, every day' },
  { num: 'Top 3', label: 'preschool · 2026' },
  { num: '100%', label: 'enrichment & meals included' },
];

const pillars = [
  {
    title: 'Reggio-inspired philosophy',
    body: 'Children learn through active exploration and play, expressing themselves in a “hundred languages.” We document each child’s journey in their own binder.',
    href: '/philosophy/',
    cta: 'Our approach',
  },
  {
    title: 'Emotional literacy',
    body: 'Every day we coach children to name, understand, and manage feelings, resolving conflict peacefully. It’s the skill that shapes resilient, kind humans.',
    href: '/emotional-literacy/',
    cta: 'Why it matters',
  },
  {
    title: 'Bilingual: daily Spanish',
    body: 'Spanish is woven into every day through songs, play, and conversation. Children build genuine familiarity with a second language.',
    href: '/bilingual/',
    cta: 'Our bilingual day',
  },
];

// Whole-child curriculum across five domains (client's framework).
const curriculum = [
  {
    icon: iconAcademic,
    title: 'Academic Foundations',
    items: ['Language & Literacy', 'Mathematics', 'Science'],
    tint: 'mint',
  },
  {
    icon: iconArts,
    title: 'Creative Arts & Enrichment',
    items: ['Music', 'Dance', 'Art', 'Drama'],
    tint: 'peach',
  },
  {
    icon: iconPhysical,
    title: 'Physical Development & Wellness',
    items: ['Yoga', 'Movement', 'Outdoor Play'],
    tint: 'sky',
  },
  {
    icon: iconLife,
    title: 'Life Skills',
    items: ['Cooking', 'Gardening', 'Practical Skills'],
    tint: 'butter',
  },
  {
    icon: iconSocial,
    title: 'Social-Emotional Development',
    items: ['Emotional Literacy', 'Self-Regulation', 'Empathy', 'Conflict Resolution'],
    tint: 'plum',
  },
];

---

<BaseLayout description={metaDescription} schema={homepageSchema}>
  <!-- ===================== FOLD 1 — HERO ===================== -->
  <section class="hero">
    <Image
      src={heroAsset}
      alt={images.hero.alt}
      class="hero__bg"
      widths={[480, 768, 1024, 1366, 1920]}
      sizes="100vw"
      format="webp"
      quality={68}
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />
    <div class="hero__scrim"></div>
    <div class="container hero__inner">
      <div class="hero__copy stack">
        <a href="/testimonials/" class="award">
          <span class="award__star" aria-hidden="true">★</span>
          <span>
            <strong>{site.award.title}</strong>
            <small>{site.award.by} · {site.facts.accreditation}</small>
          </span>
        </a>
        <h1>Reggio-Inspired Preschool in Culver City &amp; West LA</h1>
        <p class="hero-tagline">{site.tagline}</p>
        <p class="lead">
          A boutique preschool and toddler program with <strong>daily Spanish</strong>,
          enrichment-rich curriculum, and <strong>nutritious meals</strong> included — for
          ages {ageRange}.
        </p>
        <div class="hero__actions">
          <a href="/contact/" class="btn btn--primary btn--lg">Book a Tour</a>
          <a href="/philosophy/" class="btn btn--ghost btn--lg">See our approach</a>
        </div>
        <p class="hero__trust">
          Licensed #{site.facts.license} · {site.facts.accreditation} · {site.facts.hours}
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== TRUST BAND ===================== -->
  <section class="section--sand stats">
    <div class="container stats__grid">
      {
        stats.map((s) => (
          <div class="stat">
            <span class="stat__num">{s.num}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===================== FOLD 2 — WHY US ===================== -->
  <section class="section section--cream section--cream-gap">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Why families choose us</p>
        <h2>More than a preschool. A small world built around your child</h2>
        <p class="lead muted">
          For over fourteen years, Valentina and her team have raised
          well-rounded, kind little humans in a home-like setting where no child
          gets lost in the shuffle.
        </p>
      </div>
      <div class="grid grid-3">
        {
          pillars.map((p) => (
            <article class="card stack">
              <h3>{p.title}</h3>
              <p>{p.body}</p>
              <a href={p.href} class="card__link">
                {p.cta} →
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== CURRICULUM / A DAY FULL OF DISCOVERY ========= -->
  <section class="section section--mint">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">All included in tuition</p>
        <h2>A day full of discovery</h2>
        <p class="lead muted">
          We nurture the whole child across five connected domains, woven
          through play, every single day.
        </p>
      </div>
      <div class="curriculum">
        {
          curriculum.map((c) => (
            <article class={`curric-row curric-row--${c.tint}`}>
              <h3 class="curric-row__title">
                <Image
                  src={c.icon}
                  alt=""
                  class="curric-row__icon"
                  width={96}
                  height={96}
                  format="webp"
                  loading="lazy"
                />
                {c.title}
              </h3>
              <ul class="curric-tags">
                {c.items.map((it) => (
                  <li>{it}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
      <p class="curric-cta">
        <a href="/programs/" class="btn btn--ghost">Programs by age</a>
        <a href="/enrichment/" class="btn btn--ghost">Explore enrichment</a>
      </p>
    </div>
  </section>

  <!-- ===================== BOOK ===================== -->
  <section class="section book-spotlight" id="valentinas-book" aria-labelledby="book-heading">
    <div class="container">
      <aside class="book-spotlight__banner">
        <a
          href={site.book.href}
          class="book-spotlight__cover-link"
          rel="noopener noreferrer"
          target="_blank"
          aria-label={`View ${site.book.title} on Amazon`}
        >
          <span class="book-spotlight__cover-frame">
            <Image
              src={bookCover}
              alt={`${site.book.title} — early childhood parenting guide by ${site.book.author}`}
              class="book-spotlight__cover"
              widths={[240, 320, 400, 480]}
              sizes="(max-width: 640px) 200px, 240px"
              format="webp"
              quality={88}
              loading="lazy"
            />
          </span>
          <span class="book-spotlight__cover-hint">View on Amazon</span>
        </a>
        <div class="book-spotlight__copy">
          <p class="book-spotlight__eyebrow">Valentina's Book</p>
          <h2 id="book-heading" class="book-spotlight__title">{site.book.title}</h2>
          <p class="book-spotlight__subtitle muted">{site.book.subtitle}</p>
          <p class="book-spotlight__lead">{site.book.blurb}</p>
          <p class="book-spotlight__cta">
            <a
              href={site.book.href}
              class="btn btn--primary"
              rel="noopener noreferrer"
              target="_blank"
            >
              View on Amazon
            </a>
          </p>
        </div>
      </aside>
    </div>
  </section>

  <!-- ===================== FOLD 3 — TESTIMONIALS ===================== -->
  <section class="section section--cream section--cream-gap">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow eyebrow--rated">
          <span class="eyebrow__stars" aria-hidden="true">★★★★★</span>
          Reviews from real families
        </p>
        <h2>“No child gets left behind.”</h2>
      </div>
      <div class="grid grid-3">
        {
          featured.map((t) => (
            <figure class="card quote stack">
              <blockquote>“{t.quote}”</blockquote>
              <figcaption>
                <strong>{t.author}</strong>
                <span class="muted">{t.location} · {t.dateDisplay}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
      <p class="text-center" style="margin-top:2rem">
        <a href="/testimonials/" class="btn btn--ghost">Read all reviews</a>
      </p>
    </div>
  </section>

  <!-- ===================== FOLD 4 — INSTAGRAM ===================== -->
  <section class="section section--sky">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">A peek into our week</p>
        <h2>Life at Valentina’s</h2>
        <p class="muted">
          Follow along at
          <a href={site.social.instagram} rel="noopener" target="_blank"
            >{site.social.instagramHandle}</a
          >
        </p>
      </div>
      <div class="ig-grid">
        {
          (
            [
              'igGarden',
              'igPaint',
              'igYoga',
              'igCooking',
              'igCircle',
              'igArt',
              'igOutdoor',
              'igReading',
            ] as const
          ).map((name) => (
            <Img name={name} ratio="1/1" width={500} />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--mint">
    <div class="container container-narrow text-center">
      <p class="lead muted" style="margin:0;">
        On the Culver City border in Palms ({site.nap.postalCode}), we welcome families from{' '}
        {site.areasServed.slice(0, -1).join(', ')}, and {site.areasServed.at(-1)} — a boutique
        preschool and toddler childcare program with full-day hours for working Westside parents.
      </p>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  .hero {
    position: relative;
    background-color: var(--color-primary-dark);
    display: flex;
    align-items: center;
    min-height: clamp(34rem, 78vh, 46rem);
    padding-block: clamp(3rem, 8vw, 6rem);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
        100deg,
        rgba(28, 50, 35, 0.86) 0%,
        rgba(28, 50, 35, 0.7) 55%,
        rgba(28, 50, 35, 0.28) 82%,
        rgba(28, 50, 35, 0.12) 100%
      ),
      linear-gradient(0deg, rgba(28, 50, 35, 0.35), transparent 45%);
  }
  .hero__inner {
    position: relative;
    z-index: 1;
  }
  .hero__copy {
    max-width: 56rem;
  }
  .hero h1 {
    color: var(--color-white);
    text-wrap: balance;
  }
  .hero-tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    font-style: italic;
    color: rgba(255, 253, 247, 0.92);
    margin: 0;
    max-width: 28rem;
  }
  .hero .lead {
    color: rgba(255, 253, 247, 0.92);
    max-width: 44rem;
  }
  .hero .lead strong {
    color: var(--color-white);
  }
  .hero__actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .hero__trust {
    font-size: 0.88rem;
    color: rgba(255, 253, 247, 0.8);
  }
  /* On the dark hero, make the outline button readable. */
  .hero .btn--ghost {
    color: var(--color-white);
    border-color: rgba(255, 253, 247, 0.7);
  }
  .hero .btn--ghost:hover {
    background: var(--color-white);
    color: var(--color-primary-dark);
    border-color: var(--color-white);
  }
  .award {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--color-white);
    border: 1px solid var(--color-primary-light);
    border-radius: var(--radius-pill);
    padding: 0.6rem 1.1rem 0.6rem 0.6rem;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    width: fit-content;
  }
  .award__star {
    display: grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #6b4e16;
    font-size: 1rem;
  }
  .award strong {
    display: block;
    font-size: 0.9rem;
    color: var(--color-primary-dark);
    line-height: 1.1;
  }
  .award small {
    color: var(--color-ink-muted);
    font-size: 0.75rem;
  }

  /* Homepage cream sections follow contrasting bands, so they need their
     normal top padding back (the global .section--cream zeroes it for spoke
     pages where it flows out of a same-color PageHero). */
  .section--cream-gap {
    padding-top: var(--section-pad);
  }

  /* Rating eyebrow: gold stars sitting neatly beside the label. */
  .eyebrow--rated {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .eyebrow__stars {
    color: var(--color-accent);
    letter-spacing: 0.08em;
    font-size: 1rem;
    line-height: 1;
  }

  .stats {
    padding-block: clamp(2rem, 4vw, 3rem);
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat__num {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--color-secondary-dark);
    line-height: 1;
  }
  .stat__label {
    display: block;
    margin-top: 0.4rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    font-size: 0.95rem;
  }

  .card__link {
    font-weight: 800;
    text-decoration: none;
    color: var(--color-secondary-dark);
  }

  .book-spotlight {
    background: var(--color-surface);
    padding-block: clamp(2.75rem, 6vw, 4.5rem);
  }
  .book-spotlight__banner {
    display: grid;
    grid-template-columns: minmax(10rem, 13.5rem) 1fr;
    gap: clamp(1.75rem, 4vw, 2.75rem);
    align-items: center;
    max-width: 52rem;
    margin-inline: auto;
    padding: clamp(1.5rem, 3.5vw, 2.25rem);
    background: linear-gradient(
      128deg,
      var(--color-peach) 0%,
      var(--color-butter) 58%,
      var(--color-white) 100%
    );
    border: 1px solid rgba(238, 108, 69, 0.22);
    border-left: 6px solid var(--color-secondary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .book-spotlight__cover-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius);
    transition: transform 0.2s ease;
  }
  .book-spotlight__cover-link:hover,
  .book-spotlight__cover-link:focus-visible {
    transform: translateY(-2px);
  }
  .book-spotlight__cover-link:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 4px;
  }
  .book-spotlight__cover-frame {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0;
    background: transparent;
    border-radius: var(--radius-lg);
    transition: transform 0.2s ease;
  }
  .book-spotlight__cover-link:hover .book-spotlight__cover-frame,
  .book-spotlight__cover-link:focus-visible .book-spotlight__cover-frame {
    transform: scale(1.02);
  }
  .book-spotlight__cover {
    display: block;
    width: 100%;
    max-width: 11.5rem;
    height: auto;
    border-radius: calc(var(--radius-lg) - 6px);
    box-shadow: 0 8px 24px rgba(46, 42, 38, 0.16);
  }
  .book-spotlight__cover-hint {
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-secondary-dark);
  }
  .book-spotlight__copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0;
  }
  .book-spotlight__eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-secondary-dark);
  }
  .book-spotlight__title {
    margin: 0 0 0.85rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-primary-dark);
  }
  .book-spotlight__subtitle {
    margin: 0 0 1.35rem;
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .book-spotlight__lead {
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0;
    max-width: 32rem;
  }
  .book-spotlight__cta {
    margin: 1.75rem 0 0;
  }

  .curriculum {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 920px;
    margin-inline: auto;
  }
  .curric-row {
    display: grid;
    grid-template-columns: 15rem 1fr;
    gap: 1.5rem;
    align-items: center;
    background: var(--color-white);
    border: 1px solid rgba(167, 196, 176, 0.5);
    border-left: 6px solid var(--color-primary);
    border-radius: var(--radius);
    padding: 1.1rem 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .curric-row--mint {
    border-left-color: var(--color-primary);
  }
  .curric-row--peach {
    border-left-color: var(--color-secondary);
  }
  .curric-row--sky {
    border-left-color: var(--color-sky);
  }
  .curric-row--butter {
    border-left-color: var(--color-accent);
  }
  .curric-row--plum {
    border-left-color: #a86fb0;
  }
  .curric-row__title {
    font-size: 1.1rem;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .curric-row__icon {
    flex: none;
    width: 2.6rem;
    height: 2.6rem;
    object-fit: contain;
  }
  .curric-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .curric-tags li {
    background: var(--color-surface);
    border: 1px solid rgba(167, 196, 176, 0.4);
    border-radius: var(--radius-pill);
    padding: 0.35em 0.85em;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .curric-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem 1rem;
    margin-top: 2.25rem;
    text-align: center;
  }
  @media (max-width: 640px) {
    .curric-row {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }
  }

  .quote blockquote {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    line-height: 1.4;
    color: var(--color-primary-dark);
  }
  .quote figcaption {
    display: flex;
    flex-direction: column;
  }

  .ig-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.85rem;
  }

  @media (max-width: 880px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 1rem;
    }
    .ig-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .book-spotlight__banner {
      grid-template-columns: 1fr;
      max-width: 24rem;
    }
    .book-spotlight__cover-link {
      max-width: 14rem;
      margin-inline: auto;
    }
    .book-spotlight__copy {
      align-items: flex-start;
    }
  }
</style>
