---
interface Props {
  id: string;
  name: string;
  min: string;
  max: string;
}
const { id, name, min, max } = Astro.props;
---

<div class="date-picker" data-min={min} data-max={max}>
  <input type="hidden" {id} {name} value="" />
  <button
    type="button"
    class="date-picker__trigger"
    id={`${id}-trigger`}
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-labelledby={`${id}-label`}
  >
    <span class="date-picker__value">Select a date</span>
    <svg class="date-picker__icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
      <rect x="3" y="5" width="18" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="1.75"></rect>
      <path d="M3 9h18M8 3v4M16 3v4" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"></path>
    </svg>
  </button>
  <div class="date-picker__popover" role="dialog" aria-modal="true" hidden>
    <div class="date-picker__header">
      <button type="button" class="date-picker__nav" data-dir="prev" aria-label="Previous month">‹</button>
      <span class="date-picker__month" aria-live="polite"></span>
      <button type="button" class="date-picker__nav" data-dir="next" aria-label="Next month">›</button>
    </div>
    <div class="date-picker__weekdays" aria-hidden="true">
      <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
    </div>
    <div class="date-picker__grid" role="grid"></div>
    <div class="date-picker__footer">
      <button type="button" class="date-picker__action date-picker__clear">Clear</button>
      <button type="button" class="date-picker__action date-picker__today">Today</button>
    </div>
  </div>
</div>

<style is:global>
  .date-picker {
    position: relative;
  }
  .date-picker__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
    font: inherit;
    padding: 0.7rem 0.9rem;
    border: 1.5px solid var(--color-primary-light);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-ink);
    cursor: pointer;
    text-align: left;
  }
  .date-picker__trigger:hover {
    border-color: var(--color-primary);
  }
  .date-picker__trigger:focus-visible {
    border-color: var(--color-primary);
    outline: 2px solid rgba(79, 164, 90, 0.35);
    outline-offset: 1px;
  }
  .date-picker__trigger[aria-expanded='true'] {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }
  .date-picker__value {
    color: var(--color-ink-muted);
  }
  .date-picker__value.is-set {
    color: var(--color-ink);
    font-weight: 600;
  }
  .date-picker__icon {
    flex-shrink: 0;
    color: var(--color-primary-dark);
  }
  .date-picker__popover {
    position: absolute;
    z-index: 40;
    top: calc(100% + 0.35rem);
    left: 0;
    width: min(100%, 18rem);
    padding: 0.85rem;
    background: var(--color-white);
    border: 1.5px solid var(--color-primary-light);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
  }
  .date-picker__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.65rem;
  }
  .date-picker__month {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-primary-dark);
  }
  .date-picker__nav {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--color-mint);
    color: var(--color-primary-dark);
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
  }
  .date-picker__nav:hover {
    background: var(--color-primary-light);
  }
  .date-picker__nav:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .date-picker__weekdays,
  .date-picker__grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.2rem;
  }
  .date-picker__weekdays {
    margin-bottom: 0.35rem;
  }
  .date-picker__weekdays span {
    text-align: center;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
  }
  .date-picker__day {
    aspect-ratio: 1;
    border: 0;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--color-ink);
    font: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
  }
  .date-picker__day:hover:not(:disabled) {
    background: var(--color-mint);
  }
  .date-picker__day.is-selected {
    background: var(--color-secondary);
    color: var(--color-white);
  }
  .date-picker__day.is-selected:hover {
    background: var(--color-secondary-dark);
  }
  .date-picker__day.is-today:not(.is-selected) {
    box-shadow: inset 0 0 0 1.5px var(--color-primary);
  }
  .date-picker__day:disabled {
    color: rgba(107, 98, 88, 0.35);
    cursor: not-allowed;
  }
  .date-picker__day.is-empty {
    visibility: hidden;
    pointer-events: none;
  }
  .date-picker__footer {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.65rem;
    padding-top: 0.65rem;
    border-top: 1px solid var(--color-primary-light);
  }
  .date-picker__action {
    border: 0;
    background: transparent;
    color: var(--color-secondary-dark);
    font: inherit;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
    padding: 0.25rem 0.35rem;
  }
  .date-picker__action:hover {
    text-decoration: underline;
  }
</style>
