---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  /** Tighter vertical spacing (e.g. philosophy page). */
  compact?: boolean;
}
const { eyebrow, title, lead, compact } = Astro.props;
---

<section class:list={['page-hero', { 'page-hero--compact': compact }]}>
  <div class="container-narrow stack">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
    <slot />
  </div>
</section>

<style>
  .page-hero {
    background: radial-gradient(
        100% 90% at 90% 0%,
        rgba(232, 176, 75, 0.16),
        transparent 55%
      ),
      var(--color-surface);
    padding-block: clamp(2.5rem, 6vw, 4.5rem) clamp(1.5rem, 4vw, 2.5rem);
  }
  .page-hero--compact {
    padding-block: clamp(1.75rem, 4vw, 2.75rem) clamp(0.5rem, 1.5vw, 0.85rem);
  }
  .page-hero--compact .stack > :global(* + *) {
    margin-top: 0.45em;
  }
  .page-hero--compact .lead {
    margin-bottom: 0;
  }
</style>
