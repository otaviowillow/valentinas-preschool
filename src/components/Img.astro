---
/**
 * Renders a registered image by key (see src/data/images.ts).
 * Local assets are optimized at build time (responsive WebP). Images that only
 * have a `src` (e.g. /public files) are rendered as a plain <img>.
 */
import { Image } from 'astro:assets';
import { images, type ImageKey } from '../data/images';

interface Props {
  name: ImageKey;
  ratio?: string; // e.g. "4/3", "1/1", "4/5"
  width?: number; // intrinsic width used to generate the optimized variants
  loading?: 'lazy' | 'eager';
  sizes?: string;
  class?: string;
}
const {
  name,
  ratio = '4/3',
  width = 900,
  loading = 'lazy',
  sizes,
  class: className = '',
} = Astro.props;

const img = images[name];
---

{
  img.asset ? (
    <Image
      src={img.asset}
      alt={img.alt}
      width={width}
      densities={[1, 2]}
      sizes={sizes ?? `${width}px`}
      loading={loading}
      decoding="async"
      class={`img ${className}`}
      style={`--ratio:${ratio}`}
    />
  ) : (
    <img
      src={img.src}
      alt={img.alt}
      width={width}
      loading={loading}
      decoding="async"
      class={`img ${className}`}
      style={`--ratio:${ratio}`}
    />
  )
}

<style>
  .img {
    width: 100%;
    height: auto;
    aspect-ratio: var(--ratio);
    object-fit: cover;
    display: block;
    border-radius: var(--radius-lg);
    background: var(--color-surface-2);
  }
</style>
