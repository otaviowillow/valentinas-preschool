---
interface Props {
  title?: string;
  text?: string;
}
const {
  title = 'Come see it for yourself',
  text = 'Spots are limited — we keep our family small on purpose. Book a tour or join the waitlist, and we’ll be in touch personally.',
} = Astro.props;
---

<section class="section section--forest cta-band">
  <div class="container-narrow text-center stack">
    <h2>{title}</h2>
    <p class="lead" style="color: rgba(251,247,240,0.85)">{text}</p>
    <div class="cta-band__actions">
      <a href="/contact/" class="btn btn--primary btn--lg">Book a Tour</a>
      <a href="/contact/?intent=waitlist" class="btn btn--light btn--lg"
        >Join the Waitlist</a
      >
    </div>
  </div>
</section>

<style>
  .cta-band__actions {
    display: flex;
    gap: 0.9rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
</style>
